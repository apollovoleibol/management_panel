    async function carregarChatlogSupabase(wpp) {
      const wppLimpo = String(wpp).replace(/\D/g, '');
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/chatlogs?select=*`, {
          method: 'GET',
          headers: getSupabaseHeaders()
        });
        if (!res.ok) throw new Error(await res.text());
        const data = await res.json();
        const chatlog = data.find(c => String(c.whatsapp).replace(/\D/g, '') === wppLimpo);
        renderChatlog({ status: 'success', data: chatlog || null });
      } catch (e) {
        renderChatlog({ status: 'error', message: e.message });
      }
    }

