      const s = String(status || '').toLowerCase();
      if (s === 'agendado') return 'status-agendado';
      if (s === 'cancelado')  return 'status-cancelado';
      if (s === 'em avaliação') return 'status-em-avaliacao';
      if (s === 'em cadastro') return 'status-em-cadastro';
      if (s === 'tecnofit') return 'status-tecnofit';
