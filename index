    async function carregarDadosDoSupabase() {
      appLog('Buscando agendamentos...', 'info');
      document.getElementById('loading').classList.remove('hidden');
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/tryouts?select=*&order=created_at.desc`, {
          method: 'GET',
          headers: getSupabaseHeaders()
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}: ${await res.text()}`);
        
        const data = await res.json();
        appLog('Sucesso. Total: ' + data.length, 'ok');
        processarDados(data);
      } catch (e) {
        tratarErro('Falha ao carregar dados: ' + e.message);
      }
    }

    async function salvarNoSupabase(id, payload) {
      const url = id ? `${SUPABASE_URL}/rest/v1/tryouts?id=eq.${id}` : `${SUPABASE_URL}/rest/v1/tryouts`;
      const method = id ? 'PATCH' : 'POST';
      try {
        const res = await fetch(url, {
          method: method,
          headers: getSupabaseHeaders(),
          body: JSON.stringify(payload)
        });
        if (!res.ok) throw new Error(await res.text());
        salvoSucesso();
      } catch (e) {
        salvoErro(e.message);
      }
    }

