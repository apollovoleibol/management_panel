<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <title>Gestão Apollo | Agendamentos</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <script>
    (function() {
      var h = new Date().getHours();
      if (h >= 21 || h < 7) document.documentElement.classList.add('dark');
    })();
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['"Inter"', 'sans-serif'] },
          colors: { apollo: { navy: '#0F1332', red: '#EE4036', gray: '#808083', light: '#FFFFFF' } }
        }
      }
    }
  </script>
  <style>
    body, html { min-height: 100dvh; width: 100%; margin: 0; padding: 0; background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%); color: #0F1332; font-family: 'Inter', sans-serif;}
    .dark body, .dark html { background: linear-gradient(135deg, #0a0e1b 0%, #0f132e 100%); color: white; }
    
    .bg-shape { position: fixed; border-radius: 50%; filter: blur(80px); opacity: 0.3; animation: float 15s infinite alternate ease-in-out; pointer-events: none; z-index: 0; }
    .dark .bg-shape { opacity: 0.15; } 
    .shape-1 { top: -10%; left: -10%; width: 60vw; height: 60vw; background: #EE4036; }
    .shape-2 { bottom: -15%; right: -10%; width: 70vw; height: 70vw; background: #4F46E5; animation-delay: -5s; }
    .shape-3 { top: 30%; left: 20%; width: 50vw; height: 50vw; background: #c026d3; animation-delay: -2s; }
    @keyframes float { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(40px,60px) scale(1.1); } }
    
    .glass-panel { border: 1px solid rgba(255,255,255,0.4); box-shadow: 0 8px 32px 0 rgba(0,0,0,0.05); background: rgba(255,255,255,0.5); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); }
    .dark .glass-panel { border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 8px 32px 0 rgba(0,0,0,0.3); background: rgba(15,19,50,0.5); }
    
    .glass-input { background: rgba(255,255,255,0.6); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.4); transition: all 0.3s; color: #0F1332; }
    .glass-input:focus { background: rgba(255,255,255,0.9); border-color: #EE4036; box-shadow: 0 0 0 4px rgba(238,64,54,0.15); outline: none;}
    .dark .glass-input { background: rgba(0,0,0,0.3); border-color: rgba(255,255,255,0.1); color: white; }
    .dark .glass-input:focus { background: rgba(0,0,0,0.5); border-color: #EE4036; }
    .glass-input.error { border-color: #EE4036 !important; box-shadow: 0 0 0 4px rgba(238,64,54,0.2) !important; }
    ::-webkit-scrollbar { width: 6px; height: 6px;} ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.2); border-radius: 10px; } .dark ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); }
    
    .logo-header-circle { width: 42px; height: 42px; border-radius: 50%; overflow: hidden; border: 1.5px solid white; background: white; flex-shrink: 0;}
    .icon-sun { display: none; } .dark .icon-sun { display: block; } .dark .icon-moon { display: none; }
    
    .table-header { background: rgba(0,0,0,0.03); } .dark .table-header { background: rgba(255,255,255,0.05); }
    .table-row { border-bottom: 1px solid rgba(0,0,0,0.05); transition: background 0.2s; cursor: pointer; } .table-row:hover { background: rgba(255,255,255,0.4); }
    .dark .table-row { border-bottom: 1px solid rgba(255,255,255,0.05); } .dark .table-row:hover { background: rgba(255,255,255,0.05); }
    .responsive-table table td, .responsive-table table th { vertical-align: middle; }
    
    .status-badge { padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .status-agendado { background: rgba(37, 211, 102, 0.15); color: #16a34a; } .dark .status-agendado { background: rgba(37, 211, 102, 0.2); color: #4ade80; }
    .status-cancelado { background: rgba(238, 64, 54, 0.15); color: #dc2626; } .dark .status-cancelado { background: rgba(238, 64, 54, 0.2); color: #f87171; }
    .status-pendente { background: rgba(245, 158, 11, 0.15); color: #d97706; } .dark .status-pendente { background: rgba(245, 158, 11, 0.2); color: #fbbf24; }
    .status-em-avaliacao { background: rgba(59, 130, 246, 0.15); color: #2563eb; } .dark .status-em-avaliacao { background: rgba(59, 130, 246, 0.2); color: #60a5fa; }
    .status-em-cadastro { background: rgba(16, 185, 129, 0.15); color: #059669; } .dark .status-em-cadastro { background: rgba(16, 185, 129, 0.2); color: #34d399; }
    .status-tecnofit { background: rgba(99, 102, 241, 0.15); color: #4f46e5; } .dark .status-tecnofit { background: rgba(99, 102, 241, 0.2); color: #818cf8; }

    .highlight-24h { background-color: #0F1332 !important; color: #FFFFFF !important; border-left: 4px solid #EE4036 !important; }
    .dark .highlight-24h { background-color: #FFFFFF !important; color: #0F1332 !important; }

    @media (max-width: 768px) {
      .responsive-table table, .responsive-table thead, .responsive-table tbody, .responsive-table th, .responsive-table td, .responsive-table tr { display: block; }
      .responsive-table thead tr { position: absolute; top: -9999px; left: -9999px; } 
      .responsive-table tr { border: 1px solid rgba(255,255,255,0.3) !important; border-radius: 16px; margin-bottom: 16px; padding: 16px 12px; background: rgba(255,255,255,0.3); box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
      .dark .responsive-table tr { border-color: rgba(255,255,255,0.08) !important; background: rgba(0,0,0,0.2); }
      .responsive-table td { border: none !important; position: relative; padding: 8px 0 8px 30% !important; margin-bottom: 4px; white-space: normal; }
      .responsive-table td:before { position: absolute; left: 0; top: 10px; width: 25%; padding-right: 10px; white-space: nowrap; font-weight: 800; color: #808083; text-transform: uppercase; font-size: 10px; }
      .responsive-table td:nth-of-type(1):before { content: "Atleta"; } .responsive-table td:nth-of-type(2):before { content: "Contato"; }
      .responsive-table td:nth-of-type(3):before { content: "Data"; } .responsive-table td:nth-of-type(4):before { content: "Local"; }
      .responsive-table td:nth-of-type(5):before { content: "Status"; }
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .loader { border: 3px solid rgba(238, 64, 54, 0.2); border-top-color: #EE4036; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 40px auto; }
    
    .liquid-card-kpi { border-radius: 24px; background: rgba(255, 255, 255, 0.6); backdrop-filter: blur(24px) saturate(200%); border: 1px solid rgba(255, 255, 255, 0.9); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); cursor: pointer; position: relative; overflow: hidden; transform-style: preserve-3d; will-change: transform; transition: box-shadow 0.4s ease, border-color 0.4s ease, transform 0.1s ease-out; }
    .dark .liquid-card-kpi { background: rgba(0, 0, 0, 0.3); border-color: rgba(255, 255, 255, 0.1); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2); }
    .liquid-card-kpi:hover { transform: rotateX(var(--x-rotation, 0deg)) rotateY(var(--y-rotation, 0deg)) scale(1.03); box-shadow: 0 20px 40px rgba(10, 78, 228, 0.12); border-color: #ffffff; }
    .dark .liquid-card-kpi:hover { border-color: rgba(255,255,255,0.3); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4); }
    
    .kpi-front { transition: all 0.4s ease; } .kpi-back { transition: all 0.4s ease; opacity: 0; pointer-events: none; }
    .liquid-card-kpi.show-chart .kpi-front { filter: blur(8px); opacity: 0.15; }
    .liquid-card-kpi.show-chart .kpi-back { opacity: 1; pointer-events: auto; }
    .icon-glass { background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(255,255,255,0.4)); box-shadow: 0 4px 15px rgba(0,0,0,0.05), inset 0 1px 0 rgba(255,255,255,1); }
    .dark .icon-glass { background: linear-gradient(135deg, rgba(255,255,255,0.2), rgba(255,255,255,0.05)); box-shadow: 0 4px 15px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1); }
    
    .modal-overlay { display: none; } .modal-overlay.open { display: flex; animation: fadeIn 0.3s forwards; }
    @keyframes fadeIn { from { opacity: 0; backdrop-filter: blur(0px); } to { opacity: 1; backdrop-filter: blur(16px); } }
    
    .filter-popover { display: none; position: absolute; right: 0; top: 100%; margin-top: 8px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); z-index: 50; width: 160px; overflow: hidden; }
    .dark .filter-popover { background: #1a1e3d; border-color: rgba(255,255,255,0.1); }
    .filter-popover.open { display: block; }
    .filter-option { padding: 10px 16px; font-size: 12px; cursor: pointer; color: #374151; font-weight: 500; }
    .dark .filter-option { color: #d1d5db; }
    .filter-option:hover { background: #f3f4f6; }
    .dark .filter-option:hover { background: rgba(255,255,255,0.05); }
    
    .custom-calendar { display: none; position: absolute; z-index: 100; background: white; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 1px solid #e5e7eb; padding: 12px; width: 280px; margin-top: 4px; }
    .dark .custom-calendar { background: #1a1e3d; border-color: rgba(255,255,255,0.1); }
    .custom-calendar.open { display: block; }
    .cal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-weight: 600; font-size: 14px; }
    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; }
    .cal-day-name { font-size: 10px; font-weight: 700; color: #9ca3af; text-transform: uppercase; }
    .cal-day { padding: 6px 0; font-size: 13px; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
    .cal-day:hover:not(.disabled) { background: rgba(238,64,54,0.1); color: #EE4036; }
    .cal-day.disabled { opacity: 0.3; cursor: not-allowed; }
    .cal-day.selected { background: #EE4036; color: white; font-weight: bold; }
    
    .chat-bubble { max-width: 82%; padding: 10px 14px; border-radius: 18px; font-size: 13px; line-height: 1.5; position: relative; word-wrap: break-word; }
    .chat-bubble.bot  { background: #ffffff; color: #0F1332; border-bottom-left-radius: 4px; align-self: flex-start; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
    .dark .chat-bubble.bot  { background: rgba(255,255,255,0.08); color: #e2e8f0; }
    .chat-bubble.user { background: #EE4036; color: white; border-bottom-right-radius: 4px; align-self: flex-end; box-shadow: 0 2px 8px rgba(238,64,54,0.3); }
    .chat-time { font-size: 10px; opacity: 0.55; margin-top: 4px; text-align: right; }

    #debug-toggle { position: fixed; bottom: 24px; left: 24px; z-index: 9999; width: 36px; height: 36px; border-radius: 50%; background: rgba(0,0,0,0.5); color: white; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.3); opacity: 0.5; transition: opacity 0.2s; }
    #debug-toggle:hover { opacity: 1; }
    #debug-panel { display: none; position: fixed; bottom: 70px; left: 16px; z-index: 9998; width: min(420px, calc(100vw - 32px)); max-height: 300px; background: rgba(10,14,27,0.97); color: #4ade80; font-family: monospace; font-size: 11px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); overflow-y: auto; padding: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
    #debug-panel.open { display: block; }
    .dbg-line { padding: 2px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .dbg-line.err { color: #f87171; }
    .dbg-line.warn { color: #fbbf24; }
    .dbg-line.info { color: #60a5fa; }
    .dbg-line.ok { color: #4ade80; }
  </style>
</head>
<body class="relative flex flex-col p-0 md:p-6 w-full max-w-[100vw] overflow-x-hidden font-sans">
  
  <div id="login-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#0F1332] bg-cover bg-center">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-md"></div>
    
    <div class="glass-panel relative z-10 w-full max-w-md p-8 m-4 rounded-[32px] flex flex-col items-center animate__animated animate__fadeInUp">
      <div class="logo-header-circle w-16 h-16 mb-4 flex items-center justify-center shadow-lg">
        <span style="color:#EE4036;font-weight:800;font-size:24px;">A</span>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Painel Apollo</h2>
      <p class="text-gray-600 dark:text-white/60 text-sm mb-8 text-center">Faça login para gerenciar os agendamentos</p>
  
      <form id="formLogin" class="w-full space-y-4" onsubmit="realizarLogin(event)">
        <div>
          <label class="block text-[11px] font-bold text-gray-500 dark:text-white/70 uppercase tracking-widest mb-1">E-mail</label>
          <input type="email" id="loginEmail" required class="glass-input w-full h-[50px] px-4 rounded-[16px] placeholder-gray-400 dark:placeholder-white/40" placeholder="seu@email.com">
        </div>
        <div>
          <label class="block text-[11px] font-bold text-gray-500 dark:text-white/70 uppercase tracking-widest mb-1">Senha</label>
          <input type="password" id="loginSenha" required class="glass-input w-full h-[50px] px-4 rounded-[16px] placeholder-gray-400 dark:placeholder-white/40" placeholder="••••••••">
        </div>
        
        <div id="loginError" class="hidden text-[#EE4036] text-xs font-bold text-center bg-[#EE4036]/10 py-2 rounded-lg mt-2">
          Credenciais inválidas. Tente novamente.
        </div>
  
        <button type="submit" id="btnLogin" class="w-full h-[50px] mt-6 bg-[#EE4036] hover:bg-[#FF554A] text-white font-bold rounded-[16px] shadow-lg flex justify-center items-center gap-2 transition-all active:scale-95">
          Acessar Painel
        </button>
      </form>
    </div>
  </div>

  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
    <div class="bg-shape shape-1"></div><div class="bg-shape shape-2"></div><div class="bg-shape shape-3"></div>
  </div>
  <div class="w-full glass-panel md:rounded-[36px] overflow-hidden flex flex-col relative z-10 min-h-[100dvh] md:min-h-[90vh] border-0 md:border">
    
    <header class="border-b border-gray-200/30 dark:border-white/10 px-6 py-5 flex justify-between items-center bg-white/30 dark:bg-black/20 shrink-0">
      <div class="flex items-center gap-4">
        <div class="logo-header-circle flex items-center justify-center shadow-md">
          <img src="https://i.imgur.com/TPTVLAJ.png" alt="Apollo" onerror="this.style.display='none'; this.parentElement.innerHTML='<span style=\'color:#EE4036;font-weight:800;\'>A</span>'">
        </div>
        <div class="flex flex-col">
          <h1 class="font-bold text-apollo-navy dark:text-white text-[18px] tracking-tight leading-none">Gestão de Agendamentos</h1>
          <span class="text-apollo-navy/60 dark:text-gray-400 text-[12px] mt-1 font-medium" id="userEmailDisplay">Aguardando login...</span>
        </div>
      </div>
      <button id="themeToggle" class="w-10 h-10 flex items-center justify-center rounded-full bg-white/50 dark:bg-black/30 hover:bg-white dark:hover:bg-black/50 transition-colors shadow-sm">
        <svg class="icon-sun w-5 h-5 text-gray-800 dark:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg class="icon-moon w-5 h-5 text-gray-800 dark:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
    </header>
    <main class="flex-1 flex flex-col w-full p-4 md:p-6 lg:p-8 relative overflow-hidden">
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-6">
        <div class="[perspective:800px] h-36 md:h-40">
          <div class="liquid-card-kpi w-full h-full" onclick="this.classList.toggle('show-chart')">
            <div class="kpi-front absolute inset-0 p-5 md:p-6 flex flex-col justify-between">
              <div class="flex justify-between items-start z-10">
                <span class="text-[11px] md:text-xs uppercase tracking-widest font-bold text-gray-500 dark:text-gray-400">Total Registros</span>
                <div class="w-10 h-10 rounded-full icon-glass flex items-center justify-center text-apollo-navy dark:text-white">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
              </div>
              <div class="flex items-end gap-2 z-10 mt-auto">
                <span id="kpi-total" class="text-5xl md:text-6xl font-normal text-gray-900 dark:text-white leading-none tracking-tight">0</span>
              </div>
              <div id="spark-total" class="absolute bottom-4 right-4 w-[45%] h-12 pointer-events-none opacity-100 z-0"></div>
            </div>
            <div class="kpi-back absolute inset-0 p-4 flex flex-col items-center justify-center bg-white/80 dark:bg-black/60 backdrop-blur-md rounded-[24px]">
              <h4 class="text-[10px] uppercase font-bold text-gray-800 dark:text-gray-300 mb-1 tracking-widest">Evolução (Semanas)</h4>
              <div class="w-full h-full flex-1 relative"><canvas id="chart-total"></canvas></div>
            </div>
          </div>
        </div>
        <div class="[perspective:800px] h-36 md:h-40">
          <div class="liquid-card-kpi w-full h-full" onclick="this.classList.toggle('show-chart')">
            <div class="kpi-front absolute inset-0 p-5 md:p-6 flex flex-col justify-between">
              <div class="flex justify-between items-start z-10">
                <span class="text-[11px] md:text-xs uppercase tracking-widest font-bold text-[#16a34a] dark:text-[#4ade80]">Agendados</span>
                <div class="w-10 h-10 rounded-full icon-glass flex items-center justify-center text-[#16a34a] dark:text-[#4ade80]">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
              </div>
              <div class="flex items-end gap-2 z-10 mt-auto">
                <span id="kpi-confirmados" class="text-5xl md:text-6xl font-normal text-gray-900 dark:text-white leading-none tracking-tight">0</span>
              </div>
              <div id="spark-confirmados" class="absolute bottom-4 right-4 w-[45%] h-12 pointer-events-none opacity-100 z-0"></div>
            </div>
            <div class="kpi-back absolute inset-0 p-4 flex flex-col items-center justify-center bg-white/80 dark:bg-black/60 backdrop-blur-md rounded-[24px]">
              <h4 class="text-[10px] uppercase font-bold text-gray-800 dark:text-gray-300 mb-1 tracking-widest">Agendamentos Semanais</h4>
              <div class="w-full h-full flex-1 relative"><canvas id="chart-confirmados"></canvas></div>
            </div>
          </div>
        </div>
        <div class="[perspective:800px] h-36 md:h-40">
          <div class="liquid-card-kpi w-full h-full" onclick="this.classList.toggle('show-chart')">
            <div class="kpi-front absolute inset-0 p-5 md:p-6 flex flex-col justify-between">
              <div class="flex justify-between items-start z-10">
                <span class="text-[11px] md:text-xs uppercase tracking-widest font-bold text-[#4F46E5] dark:text-[#818cf8]">Reagendados</span>
                <div class="w-10 h-10 rounded-full icon-glass flex items-center justify-center text-[#4F46E5] dark:text-[#818cf8]">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
              </div>
              <div class="flex items-end gap-2 z-10 mt-auto">
                <span id="kpi-reagendados" class="text-5xl md:text-6xl font-normal text-gray-900 dark:text-white leading-none tracking-tight">0</span>
              </div>
              <div id="spark-reagendados" class="absolute bottom-4 right-4 w-[45%] h-12 pointer-events-none opacity-100 z-0"></div>
            </div>
            <div class="kpi-back absolute inset-0 p-4 flex flex-col items-center justify-center bg-white/80 dark:bg-black/60 backdrop-blur-md rounded-[24px]">
              <h4 class="text-[10px] uppercase font-bold text-gray-800 dark:text-gray-300 mb-1 tracking-widest">Reagendamentos Semanais</h4>
              <div class="w-full h-full flex-1 relative"><canvas id="chart-reagendados"></canvas></div>
            </div>
          </div>
        </div>
        <div class="[perspective:800px] h-36 md:h-40">
          <div class="liquid-card-kpi w-full h-full" onclick="this.classList.toggle('show-chart')">
