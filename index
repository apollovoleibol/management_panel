          tr.onclick = function() { showRowActions(row); };
          tr.innerHTML =
            '<td class="px-5 py-4">' + nomeDisplay + '</td>' +
            '<td class="px-5 py-4"><div class="flex items-center gap-2">' + iconPhone + '<span class="text-[14px] w-[125px] shrink-0 font-medium">' + formatarWhatsApp(row.whatsapp) + '</span>' + linkWA + '</div></td>' +
            '<td class="px-5 py-4"><div class="flex items-center font-medium text-[14px] gap-2">' + iconCal + ' <span>' + formatarDataSimples(row.data_agendamento) + '</span> ' + reagendamentoBadge + '</div></td>' +
            '<td class="px-5 py-4"><div class="flex items-center gap-2 font-bold text-[13px]">' + iconTeam + '<span class="truncate max-w-[200px]">' + (row.equipe || '—') + '</span></div><div class="text-[11px] opacity-60 leading-tight mt-1 whitespace-normal md:whitespace-nowrap max-w-[300px] truncate ml-7">' + (row.local || '—') + '</div></td>' +
            '<td class="px-5 py-4"><span class="status-badge ' + getBadgeClass(row.status) + '">' + (row.status || 'Pendente') + '</span></td>';
          tbody.appendChild(tr);
        });
      }

      if (futuros.length > 0) renderRowArr(futuros);
      if (passados.length > 0) {
        if (futuros.length > 0) {
          const trDiv = document.createElement('tr');
          trDiv.innerHTML = '<td colspan="5" class="py-3 text-center bg-gray-100/50 dark:bg-white/5 border-y border-gray-200 dark:border-white/10 font-bold text-[10px] text-gray-500 uppercase tracking-widest cursor-default">⬇ Agendamentos Passados ⬇</td>';
          tbody.appendChild(trDiv);
        }
        renderRowArr(passados);
      }
    }

    function aplicarFiltros() {
      const termo = document.getElementById('searchName').value.toLowerCase();
      const status = document.getElementById('filterStatus').value.toLowerCase();
      const equipe = document.getElementById('filterEquipe').value;
      const filtrados = dadosOriginais.filter(function(d) {
        const matchNome   = String(d.nome || '').toLowerCase().includes(termo) || String(d.whatsapp || '').toLowerCase().includes(termo) || String(d.nome_menor || '').toLowerCase().includes(termo);
        const matchStatus = status === '' || String(d.status || '').toLowerCase() === status;
        const matchEquipe = equipe === '' || d.equipe === equipe;
        return matchNome && matchStatus && matchEquipe;
      });
      renderizarTabela(filtrados);
    }

    function toggleFilterMenu(e, id) {
      e.stopPropagation();
      document.querySelectorAll('.filter-popover').forEach(function(p) { p.classList.remove('open'); });
      document.getElementById('popover-' + id).classList.toggle('open');
    }

    function sortTable(column, dir) {
      dadosOriginais.sort(function(a, b) {
        let valA, valB;
        if (column === 'nome')   { valA = String(a.nome_menor || a.nome || '').toLowerCase(); valB = String(b.nome_menor || b.nome || '').toLowerCase(); }
        if (column === 'data')   { valA = a.data_agendamento ? new Date(a.data_agendamento) : new Date(0); valB = b.data_agendamento ? new Date(b.data_agendamento) : new Date(0); }
        if (column === 'equipe') { valA = String(a.equipe || '').toLowerCase(); valB = String(b.equipe || '').toLowerCase(); }
        if (valA < valB) return dir === 'asc' ? -1 : 1;
        if (valA > valB) return dir === 'asc' ? 1  : -1;
        return 0;
      });
      aplicarFiltros();
    }

    function showRowActions(data) {
      selectedRowData = data;
      document.getElementById('modal-actions').classList.add('open');
    }

    function closeModals() {
      document.querySelectorAll('.modal-overlay').forEach(function(m) { m.classList.remove('open'); });
      isFormDirty = false;
    }

    function attemptCloseFormModal() {
      if (isFormDirty) document.getElementById('modal-dirty').classList.add('open');
      else forceCloseForm();
    }

    function forceCloseForm() {
      document.getElementById('modal-dirty').classList.remove('open');
      document.getElementById('modal-form').classList.remove('open');
      isFormDirty = false;
    }

    function openAddModal() {
      selectedRowData = null;
      document.getElementById('formAgendamento').reset();
      document.getElementById('formId').value = '';
      document.getElementById('modal-form-title').innerText = 'Novo Agendamento';
      document.getElementById('containerStatus').classList.add('hidden');
      document.getElementById('wppError').classList.add('hidden');
      document.getElementById('formWpp').classList.remove('error');
      
      document.getElementById('btnExcluirModal').classList.add('hidden');
      document.getElementById('formStatus').innerHTML = '<option value="Agendado">Agendado</option><option value="Cancelado">Cancelado</option>';

      syncFormFields();
      document.getElementById('modal-form').classList.add('open');
      isFormDirty = false;
    }

    function openEditModal() {
      if (!selectedRowData) return;
      document.getElementById('modal-actions').classList.remove('open');
      document.getElementById('formAgendamento').reset();
      document.getElementById('formId').value = selectedRowData.id || '';
      document.getElementById('modal-form-title').innerText = 'Editar Agendamento';
      document.getElementById('formEquipe').value = selectedRowData.equipe || '';
      syncFormFields();
      document.getElementById('formNome').value = selectedRowData.nome || '';
      const fNomeMenor = document.getElementById('formNomeMenor');
      if (fNomeMenor) fNomeMenor.value = selectedRowData.nome_menor || '';
      document.getElementById('formWpp').value = formatarWhatsApp(selectedRowData.whatsapp || '');
      if (selectedRowData.data_agendamento) {
        try {
          const d = new Date(selectedRowData.data_agendamento);
          if (!isNaN(d.getTime())) {
            const dia  = String(d.getDate()).padStart(2, '0');
            const mes  = String(d.getMonth() + 1).padStart(2, '0');
            const ano  = d.getFullYear();
            const hora = String(d.getHours()).padStart(2, '0');
            const min  = String(d.getMinutes()).padStart(2, '0');
            document.getElementById('formData').value = dia + '/' + mes + '/' + ano + ' ' + hora + ':' + min;
            currentCalDate = d;
          }
        } catch (e) {}
      }
      
      document.getElementById('containerStatus').classList.remove('hidden');
      document.getElementById('btnExcluirModal').classList.remove('hidden');
      
      const currentStatus = selectedRowData.status || 'Agendado';
      const formStatus = document.getElementById('formStatus');
      formStatus.innerHTML = '<option value="Agendado">Agendado</option><option value="Cancelado">Cancelado</option>';
      if (currentStatus !== 'Agendado' && currentStatus !== 'Cancelado') {
         formStatus.innerHTML += `<option value="${currentStatus}" hidden>${currentStatus}</option>`;
      }
      formStatus.value = currentStatus;

      document.getElementById('modal-form').classList.add('open');
      isFormDirty = false;
    }

    function syncFormFields() {
      const equipe = document.getElementById('formEquipe').value;
      const conf = TEAM_CONFIG[equipe];
      const lblNome = document.getElementById('labelNomePrincipal');
      const boxMenor = document.getElementById('containerNomeMenor');
      if (conf && conf.minors) {
        lblNome.innerText = 'Nome do Responsável';
        boxMenor.classList.remove('hidden');
      } else {
        lblNome.innerText = 'Nome do Atleta';
        boxMenor.classList.add('hidden');
        document.getElementById('formNomeMenor').value = '';
      }
      document.getElementById('formData').value = '';
      renderCalendar();
    }

    function changeMonth(dir) {
      currentCalDate.setMonth(currentCalDate.getMonth() + dir);
      renderCalendar();
    }

    function renderCalendar() {
      const year = currentCalDate.getFullYear();
      const month = currentCalDate.getMonth();
      document.getElementById('cal-month-year').innerText = monthNames[month] + ' ' + year;
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const calDays = document.getElementById('cal-days');
      calDays.innerHTML = '';
      const equipe = document.getElementById('formEquipe').value;
      const conf = TEAM_CONFIG[equipe];
      const allowedDays = conf ? conf.days : [0,1,2,3,4,5,6];
      for (let i = 0; i < firstDay; i++) calDays.innerHTML += '<div></div>';
      for (let i = 1; i <= daysInMonth; i++) {
        const d = new Date(year, month, i);
        const dayOfWeek = d.getDay();
        const isValid = allowedDays.includes(dayOfWeek) && d >= new Date(new Date().setHours(0,0,0,0));
        let classes = 'cal-day' + (isValid ? '' : ' disabled');
        const inVal = document.getElementById('formData').value;
        if (inVal) {
          const parts = inVal.split(' ')[0].split('/');
          if (parseInt(parts[0]) === i && parseInt(parts[1]) === month + 1 && parseInt(parts[2]) === year) classes += ' selected';
        }
        calDays.innerHTML += '<div class="' + classes + '" onclick="selectDate(' + i + ',' + month + ',' + year + ',' + dayOfWeek + ')">' + i + '</div>';
      }
    }

    function selectDate(d, m, y, dayOfWeek) {
      const equipe = document.getElementById('formEquipe').value;
      const conf = TEAM_CONFIG[equipe];
      if (conf && !conf.days.includes(dayOfWeek)) return;
      const dia = String(d).padStart(2, '0');
      const mes = String(m + 1).padStart(2, '0');
      let time = '00:00';
      if (conf) {
        if (conf.time) time = conf.time;
        else if (conf.timeMap && conf.timeMap[dayOfWeek]) time = conf.timeMap[dayOfWeek];
      }
      document.getElementById('formData').value = dia + '/' + mes + '/' + y + ' ' + time;
      document.getElementById('custom-calendar').classList.remove('open');
      isFormDirty = true;
    }

    function handleSalvar() {
      const id      = document.getElementById('formId').value;
      const equipe  = document.getElementById('formEquipe').value;
      const nome    = document.getElementById('formNome').value;
      const fNomeMenor = document.getElementById('formNomeMenor');
      const nomeMenor = fNomeMenor ? fNomeMenor.value : '';
      const wpp     = document.getElementById('formWpp').value.replace(/\D/g, '');
      const dataStr = document.getElementById('formData').value;

      if (!equipe || !nome || !wpp || !dataStr) { alert('Preencha todos os campos obrigatórios!'); return; }
      if (wpp.length < 10) { alert('Número de WhatsApp inválido!'); return; }

      const btn = document.getElementById('btnSalvarModal');
      btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> Salvando...'; 
      btn.disabled = true;

      const parts    = dataStr.split(' ');
      const datePart = parts[0].split('/');
      const timePart = parts[1] || '00:00';
      const isoDate  = datePart[2] + '-' + datePart[1] + '-' + datePart[0] + 'T' + timePart + ':00';

      let dbStatus = selectedRowData ? selectedRowData.raw_status : 'PENDING';
      if (id) {
        const formStatusVal = document.getElementById('formStatus').value;
        if (formStatusVal === 'Agendado') dbStatus = 'CONFIRMED';
        else if (formStatusVal === 'Cancelado') dbStatus = 'CANCELLED';
      }

      const payload = {
        name: nome,
        minor_name: nomeMenor,
        whatsapp_phone: wpp,
        scheduled_at: isoDate,
        target_team: equipe,
        target_location: TEAM_CONFIG[equipe] ? TEAM_CONFIG[equipe].local : 'Ginásio Apollo'
      };
      
      if (id) payload.status = dbStatus;
      salvarNoSupabase(id, payload);
    }

    function handleExcluir() {
      const id = document.getElementById('formId').value;
      if (!id) return;
      if (confirm('ATENÇÃO!\n\nTem certeza que deseja EXCLUIR este agendamento definitivamente?\nEsta ação não pode ser desfeita e os dados serão permanentemente apagados do banco.')) {
        const btn = document.getElementById('btnExcluirModal');
        btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> Excluindo...';
        btn.disabled = true;
        excluirNoSupabase(id);
      }
    }

    function salvoSucesso() {
      forceCloseForm();
      document.getElementById('btnSalvarModal').innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg> Salvar';
      document.getElementById('btnSalvarModal').disabled = false;
      document.getElementById('btnExcluirModal').innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg> Excluir';
      document.getElementById('btnExcluirModal').disabled = false;
      carregarDadosDoSupabase();
    }

    function salvoErro(err) {
      alert('Erro na operação: ' + err);
      document.getElementById('btnSalvarModal').innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg> Salvar';
      document.getElementById('btnSalvarModal').disabled = false;
      document.getElementById('btnExcluirModal').innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg> Excluir';
      document.getElementById('btnExcluirModal').disabled = false;
    }

    function openChatlogModal() {
      if (!selectedRowData) return;
      document.getElementById('modal-actions').classList.remove('open');
      const wpp = selectedRowData.whatsapp;
      document.getElementById('chat-nome').innerText = selectedRowData.nome;
      const container = document.getElementById('chatlog-container');
      container.innerHTML = '<div class="loader m-auto"></div>';
      document.getElementById('modal-chatlog').classList.add('open');
      carregarChatlogSupabase(wpp);
    }

    function renderChatlog(res) {
      const container = document.getElementById('chatlog-container');
      container.innerHTML = '';
      if (res && res.status === 'error') {
        container.innerHTML = '<div class="text-red-500 text-center mt-10 text-sm px-4">' + res.message + '</div>';
        return;
      }
      const chatData = res.data;
      if (!chatData || !chatData.history) {
        container.innerHTML = '<div class="bg-white dark:bg-white/10 p-4 rounded-xl text-center text-sm font-medium mx-auto mt-10 text-gray-500 dark:text-gray-400">Nenhum histórico encontrado para este contato.</div>';
        return;
      }
      try {
        let history;
        if (typeof chatData.history === 'string') {
          history = JSON.parse(chatData.history);
        } else if (Array.isArray(chatData.history)) {
          history = chatData.history;
        } else {
          throw new Error('Formato inesperado de history: ' + typeof chatData.history);
        }

        history.forEach(function(msg) {
          const isBot = msg.role === 'model';
          const text  = msg.parts[0].text.replace(/\n/g, '<br>');
          const bubble = document.createElement('div');
          bubble.className = 'chat-bubble ' + (isBot ? 'bot' : 'user') + ' animate__animated animate__fadeInUp animate__faster';
          bubble.innerHTML = '<div>' + text + '</div><div class="chat-time text-[9px] ' + (isBot ? 'text-gray-400' : 'text-white/70') + '">' + (msg.timestamp || '') + '</div>';
          container.appendChild(bubble);
        });
        setTimeout(function() { container.scrollTop = container.scrollHeight; }, 100);
      } catch (e) {
        container.innerHTML = '<div class="text-red-500 text-center mt-10 text-sm px-4">Erro ao ler histórico: ' + String(e) + '</div>';
      }
    }

    function init3DCards() {
      document.querySelectorAll('.liquid-card-kpi').forEach(function(card) {
        card.addEventListener('mousemove', function(ev) {
          const bounds = card.getBoundingClientRect();
          const xP = (ev.clientX - bounds.left) / bounds.width;
          const yP = (ev.clientY - bounds.top)  / bounds.height;
          card.style.setProperty('--x-rotation', ((0.5 - yP) * 15) + 'deg');
          card.style.setProperty('--y-rotation', ((xP - 0.5) * 15) + 'deg');
        });
        card.addEventListener('mouseleave', function() {
          card.style.setProperty('--x-rotation', '0deg');
          card.style.setProperty('--y-rotation', '0deg');
        });
      });
    }

    function generateSparkline(dataArr, colorStr, id) {
      if (!dataArr || dataArr.length < 2) return '';
      const min = Math.min.apply(null, dataArr);
      const max = Math.max.apply(null, dataArr);
      const range = (max - min) || 1;
      const height = 30;

      const pts = dataArr.map(function(v, i) {
        const x = (i / (dataArr.length - 1)) * 100;
        const y = height - ((v - min) / range) * (height - 5);
        return x + ',' + y;
      });

      const pathD = 'M ' + pts[0] + (pts.length > 1 ? ' L ' + pts.slice(1).join(' L ') : '');

      return '<svg viewBox="0 0 100 ' + height + '" class="w-full h-full" preserveAspectRatio="none">' +
        '<defs><linearGradient id="grad-' + id + '" x1="0" y1="0" x2="0" y2="1">' +
          '<stop offset="0%" stop-color="' + colorStr + '" stop-opacity="0.8"/>' +
          '<stop offset="100%" stop-color="' + colorStr + '" stop-opacity="0.05"/>' +
        '</linearGradient></defs>' +
        '<path d="' + pathD + '" fill="none" stroke="url(#grad-' + id + ')" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>' +
      '</svg>';
    }
  </script>
