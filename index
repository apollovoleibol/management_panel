    function processarDados(dados) {
      document.getElementById('loading').classList.add('hidden');

      const dataArr = Array.isArray(dados) ? dados.map(function(d) {
        let rawStat = d.status || 'PENDING';
        let sUp = rawStat.toUpperCase();
        let uiStatus = 'Pendente';
        
        if (sUp === 'CONFIRMED') uiStatus = 'Agendado';
        else if (sUp === 'CANCELED' || sUp === 'CANCELLED') uiStatus = 'Cancelado';
        else if (sUp === 'PENDING') uiStatus = 'Pendente';
        else if (sUp === 'IN_EVALUATION') uiStatus = 'Em avaliação';
        else if (sUp === 'IN_REGISTRATION') uiStatus = 'Em cadastro';
        else if (sUp === 'TECNOFIT') uiStatus = 'Tecnofit';
        else uiStatus = rawStat;

        return {
          id: d.id,
          nome: d.name || d.nome,
          nome_menor: d.minor_name !== undefined ? d.minor_name : d.nome_menor,
          whatsapp: d.whatsapp_phone || d.whatsapp,
          data_agendamento: d.scheduled_at || d.data_agendamento,
          equipe: d.target_team || d.equipe,
          local: d.target_location || d.local,
          status: uiStatus,
          raw_status: rawStat,
          qtd_reagendamentos: d.reschedule_count !== undefined ? d.reschedule_count : (d.qtd_reagendamentos || 0),
          created_at: d.created_at
        };
      }) : [];

      const agora = new Date();
      dadosOriginais = dataArr.sort(function(a, b) {
        const da = a.data_agendamento ? new Date(a.data_agendamento) : new Date(0);
        const db = b.data_agendamento ? new Date(b.data_agendamento) : new Date(0);
        return Math.abs(da - agora) - Math.abs(db - agora);
      });

      popularFiltroEquipes(dadosOriginais);
      try { atualizarKPIs(dadosOriginais); } catch (e) {}
      renderizarTabela(dadosOriginais);
    }

    function popularFiltroEquipes(dados) {
      const equipes = [...new Set(dados.map(function(d) { return d.equipe; }).filter(Boolean))].sort();
      const select = document.getElementById('filterEquipe');
      equipes.forEach(function(eq) {
        if (!select.querySelector('option[value="' + eq + '"]')) {
          const opt = document.createElement('option');
          opt.value = eq; opt.textContent = eq;
          select.appendChild(opt);
        }
      });
    }

    function calcularEvolucaoSemanal(dados, keyDate, filterFn) {
      filterFn = filterFn || function() { return true; };
      const now = new Date();
      let weeks = [0, 0, 0, 0];
      dados.filter(filterFn).forEach(function(d) {
        if (!d[keyDate]) return;
        const dt = new Date(d[keyDate]);
        if (isNaN(dt.getTime())) return;
        const diffDays = Math.ceil(Math.abs(now - dt) / (1000 * 60 * 60 * 24));
        if (diffDays <= 7) weeks[3]++;
        else if (diffDays <= 14) weeks[2]++;
        else if (diffDays <= 21) weeks[1]++;
        else if (diffDays <= 28) weeks[0]++;
      });
      return weeks;
    }

    function atualizarKPIs(dados) {
      const tConf = dados.filter(function(d) { return String(d.status || '').toLowerCase() === 'agendado'; }).length;
      const tReag = dados.filter(function(d) { return Number(d.qtd_reagendamentos) > 0; }).length;
      const tCanc = dados.filter(function(d) { return String(d.status || '').toLowerCase() === 'cancelado'; }).length;
      document.getElementById('kpi-total').textContent = dados.length;
      document.getElementById('kpi-confirmados').textContent = tConf;
      document.getElementById('kpi-reagendados').textContent = tReag;
      document.getElementById('kpi-cancelados').textContent = tCanc;

      const wTotal = calcularEvolucaoSemanal(dados, 'created_at');
      const wConf  = calcularEvolucaoSemanal(dados, 'created_at', function(d) { return String(d.status || '').toLowerCase() === 'agendado'; });
      const wReag  = calcularEvolucaoSemanal(dados, 'created_at', function(d) { return Number(d.qtd_reagendamentos) > 0; });
      const wCanc  = calcularEvolucaoSemanal(dados, 'created_at', function(d) { return String(d.status || '').toLowerCase() === 'cancelado'; });

      const isDark = document.documentElement.classList.contains('dark');
      document.getElementById('spark-total').innerHTML       = generateSparkline(wTotal, isDark ? '#ffffff' : '#0F1332', 'spk-tot');
      document.getElementById('spark-confirmados').innerHTML = generateSparkline(wConf,  '#16a34a', 'spk-conf');
      document.getElementById('spark-reagendados').innerHTML = generateSparkline(wReag,  '#4F46E5', 'spk-reag');
      document.getElementById('spark-cancelados').innerHTML  = generateSparkline(wCanc,  '#EE4036', 'spk-canc');

      renderChartsBack(wTotal, wConf, wReag, wCanc);
    }

    function renderChartsBack(dTot, dConf, dReag, dCanc) {
      const isDark = document.documentElement.classList.contains('dark');
      const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
      const textColor = isDark ? 'rgba(255,255,255,0.6)' : 'rgba(0,0,0,0.6)';
      const commonOptions = {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 10 } } },
          y: { display: true, border: { display: false }, grid: { color: gridColor }, ticks: { color: textColor, font: { size: 10 }, stepSize: 1 } }
        }
      };
      const createLineChart = function(id, labels, data, color) {
        if (chartsInstance[id]) chartsInstance[id].destroy();
        const canvas = document.getElementById(id);
        if (canvas) {
          chartsInstance[id] = new Chart(canvas, {
            type: 'line',
            data: { labels: labels, datasets: [{ data: data, borderColor: color, backgroundColor: color, borderWidth: 2, tension: 0.4, pointRadius: 3 }] },
            options: commonOptions
          });
        }
      };
      const wLabels = ['Sem 1', 'Sem 2', 'Sem 3', 'Sem 4'];
      createLineChart('chart-total',       wLabels, dTot, isDark ? '#ffffff' : '#0F1332');
      createLineChart('chart-confirmados', wLabels, dConf, '#16a34a');
      createLineChart('chart-reagendados', wLabels, dReag, '#4F46E5');
      createLineChart('chart-cancelados',  wLabels, dCanc, '#EE4036');
    }

    function formatarDataSimples(dateString) {
      if (!dateString) return '—';
      try {
        const d = new Date(dateString);
        if (isNaN(d.getTime())) return dateString;
        return d.toLocaleDateString('pt-BR') + ' às ' + d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
      } catch (e) { return dateString; }
    }

    function formatarWhatsApp(numero) {
      let v = String(numero || '').replace(/\D/g, '');
      if (v.length > 10) return v.replace(/^(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
      if (v.length > 0)  return v.replace(/^(\d{2})(\d{4})(\d{4})/, '($1) $2-$3');
      return numero;
    }

